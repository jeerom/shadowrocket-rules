# rules/sr_ru_proxy.list
# Всё, что должно идти через proxy.
# Brawl Stars / Supercell продублированы также в sr_ru_extended.conf, чтобы сработать до REJECT.

# --- Brawl Stars / Supercell ---
DOMAIN,cdn.id.supercell.com
DOMAIN,assets.social.supercell.com
DOMAIN,collector.snowplow.supercell.com
DOMAIN,game.brawlstarsgame.com
DOMAIN-SUFFIX,supercell.com
DOMAIN-SUFFIX,supercell.net
DOMAIN-SUFFIX,brawlstars.com
DOMAIN-SUFFIX,brawlstarsgame.com
DOMAIN-SUFFIX,game-assets.brawlstarsgame.com
DOMAIN-KEYWORD,supercell
DOMAIN-KEYWORD,brawlstars

# --- Brawl Stars real game servers observed in log 2026-04-26 ---
# game.brawlstarsgame.com resolved to 52.33.95.61; Shadowrocket then saw raw IP:9339 and sent it FINAL,DIRECT.
# Keep these IP rules in PROXY so the actual game socket does not bypass proxy after DNS resolution.
IP-CIDR,52.33.95.61/32,no-resolve


# Supercell/game support infrastructure often seen around game launch, auth, telemetry, CDN.
# Важно: эти домены НЕ блокируем в reject, а пускаем через proxy.
DOMAIN-SUFFIX,appsflyer.com
DOMAIN-SUFFIX,appsflyersdk.com
DOMAIN-SUFFIX,adjust.com
DOMAIN-SUFFIX,adjust.io
DOMAIN-SUFFIX,unity3d.com
DOMAIN-SUFFIX,unity.com
DOMAIN-SUFFIX,unityads.unity3d.com
DOMAIN-SUFFIX,helpshift.com
DOMAIN-SUFFIX,akamaized.net
DOMAIN-SUFFIX,akamaihd.net
DOMAIN-SUFFIX,cloudfront.net
DOMAIN-SUFFIX,fastly.net
DOMAIN-SUFFIX,googleapis.com
DOMAIN-SUFFIX,gstatic.com
DOMAIN-SUFFIX,firebaseio.com
DOMAIN-SUFFIX,firebaseapp.com
DOMAIN-SUFFIX,firebaselogging-pa.googleapis.com
DOMAIN-SUFFIX,crashlytics.com


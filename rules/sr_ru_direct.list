# rules/sr_ru_direct.list
# Всё, что должно идти напрямую.
# Apple/iCloud продублированы также в sr_ru_extended.conf для надёжности.

# --- Apple / iCloud / App Store / Push ---
DOMAIN-SUFFIX,apple.com
DOMAIN-SUFFIX,icloud.com
DOMAIN-SUFFIX,icloud-content.com
DOMAIN-SUFFIX,cdn-apple.com
DOMAIN-SUFFIX,mzstatic.com
DOMAIN-SUFFIX,aaplimg.com
DOMAIN-SUFFIX,me.com
DOMAIN-SUFFIX,itunes.apple.com
DOMAIN-SUFFIX,apps.apple.com
DOMAIN-SUFFIX,gc.apple.com
DOMAIN-SUFFIX,iwork.apple.com
DOMAIN-SUFFIX,apple-mapkit.com
DOMAIN-SUFFIX,apple-cloudkit.com
DOMAIN-SUFFIX,icloud.com.cn
DOMAIN-KEYWORD,icloud
DOMAIN-KEYWORD,apple
IP-CIDR,17.0.0.0/8,no-resolve
IP-CIDR6,2403:300::/32,no-resolve
IP-CIDR6,2620:149::/32,no-resolve

# --- Local / Private networks ---
DOMAIN-SUFFIX,local
IP-CIDR,10.0.0.0/8,no-resolve
IP-CIDR,100.64.0.0/10,no-resolve
IP-CIDR,127.0.0.0/8,no-resolve
IP-CIDR,169.254.0.0/16,no-resolve
IP-CIDR,172.16.0.0/12,no-resolve
IP-CIDR,192.168.0.0/16,no-resolve
IP-CIDR,224.0.0.0/4,no-resolve
IP-CIDR,240.0.0.0/4,no-resolve


# sr_ru_reject.list
# Fast reject / technical optimization rules.
# Format: Shadowrocket RULE-SET entries without policy column.
# Used by: RULE-SET,.../sr_ru_reject.list,REJECT

# Telegram IPv6: reject fast when base config has ipv6=false.
# This avoids slow IPv6 connection attempts before Telegram falls back to IPv4.
IP-CIDR6,2001:67c:4e8::/48,no-resolve
IP-CIDR6,2001:b28:f23c::/48,no-resolve
IP-CIDR6,2001:b28:f23d::/48,no-resolve
IP-CIDR6,2001:b28:f23f::/48,no-resolve
IP-CIDR6,2a0a:f280::/32,no-resolve

# Broader community Telegram IPv6 ranges; keep here instead of PROXY while IPv6 is disabled.
IP-CIDR6,2001:b28:f23c::/47,no-resolve
IP-CIDR6,2a0a:f280::/29,no-resolve
